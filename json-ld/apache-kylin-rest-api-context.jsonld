      "@type": "xsd:string"
    },
    "project": {
      "@id": "kylin:project",
      "@type": "xsd:string"
    },
    "offset": {
      "@id": "kylin:offset",
      "@type": "xsd:integer"
    },
    "limit": {
      "@id": "kylin:limit",
